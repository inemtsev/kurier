# Copy this file to `.env` (gitignored) and fill in whichever bot token(s) you have.
# The echo-bot sample loads `.env` automatically and installs an adapter per token present:
#   ./gradlew :samples:echo-bot:run
# With no token it falls back to an in-memory console echo.
TG_TOKEN=
# Discord: needs the privileged "Message Content" intent enabled in the dev portal.
DISCORD_TOKEN=
